    "ingredients": [
      "土豆 2个",
      "西班牙火腿 50g",
      "橄榄油 1-2勺",
      "黑胡椒 少许",
      "盐 少许"
    ],
    "steps": [
      "土豆切条后擦干水分，少油煎或空气炸至金黄。",
