    "difficulty": "中等",
    "caloriesKcal": 520,
    "ingredients": [
      "紫菜 2张",
      "米饭 250g",
      "牛肉丝 120g",
      "胡萝卜丝 50g",
      "黄瓜丝 50g",
      "菠菜 50g",
      "香油 1小勺"
    ],
    "steps": [
