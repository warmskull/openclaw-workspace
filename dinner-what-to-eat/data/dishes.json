    "photo": "/images/berry-platter.jpg",
    "category": "水果",
    "tags": [
      "低卡",
      "抗氧化",
      "免烹饪"
    ],
    "prepTimeMin": 5,
    "difficulty": "简单",
    "caloriesKcal": 120,
    "ingredients": [
      "草莓 150g",
      "蓝莓 80g"
    ],
