  {
    "id": "dish-draft-007",
    "name": "蒜蓉虾配荷兰豆玉米",
    "photo": "/uploads/food-photos-20260311/jpg/IMG_6964.jpg",
    "category": "主菜",
    "tags": [
      "海鲜",
      "高蛋白",
      "快手",
      "低负担"
    ],
    "prepTimeMin": 22,
    "difficulty": "简单",
    "caloriesKcal": 460,
    "ingredients": [
      "鲜虾 10-12只",
      "荷兰豆 150g",
      "玉米 1根",
      "蒜末 2瓣",
      "橄榄油 1勺",
      "盐和黑胡椒 适量"
    ],
    "steps": [
      "虾去虾线后加少许盐和黑胡椒抓匀，静置5分钟。",
      "荷兰豆焯水1分钟后捞出，玉米蒸熟切段。",
      "热锅下油爆香蒜末，放入鲜虾翻炒至变色卷曲。",
      "将荷兰豆和玉米回锅，快速翻匀后出锅。"
    ],
    "nutritionNote": "高蛋白、膳食纤维充足，适合工作日晚饭。",
